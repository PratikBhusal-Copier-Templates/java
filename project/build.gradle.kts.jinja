import org.gradle.api.tasks.testing.logging.TestLogEvent

// Tip: Use `apply false` in the top-level build.gradle file to add a Gradle
// plugin as a build dependency but not apply it to the current (root) project.
// Don't use `apply false` in sub-projects.
//
// For more information, see the following on applying external plugins with
// same version to subprojects:
//
// - https://docs.gradle.org/current/userguide/dependency_management_basics.html
// - https://docs.gradle.org/current/samples/sample_building_java_applications_multi_project.html
// - https://docs.gradle.org/current/dsl/org.gradle.plugin.use.PluginDependenciesSpec.html#org.gradle.plugin.use.PluginDependenciesSpec:id(java.lang.String)
plugins {
    id("{{java_app_or_library}}")

    // Code Coverage
    id("jacoco")
}

group = "{{project_group_id}}"
version = "{{project_version}}"

repositories {
    mavenCentral()
}

dependencies {
    ////////////////////////////////////////////////////////////////////////////
    //                                Logging                                 //
    ////////////////////////////////////////////////////////////////////////////
    {#
    // в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
    // в”Ӯ Logging Dependency Requirements в”Ӯ log4jв”Җapi        в”Ӯ slf4jв”Җapi        в”Ӯ
    // в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
    // в”Ӯ log4jв”Җcore                      в”Ӯ log4jв”Җcore,      в”Ӯ log4jв”Җcore,      в”Ӯ
    // в”Ӯ                                 в”Ӯ log4jв”Җapi        в”Ӯ log4jв”Җapi,       в”Ӯ
    // в”Ӯ                                 в”Ӯ                  в”Ӯ log4jв”Җslf4jв”Җimpl в”Ӯ
    // в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
    // в”Ӯ logbackв”Җcore                    в”Ӯ logbackв”Җcore,    в”Ӯ logbackв”Җclassic  в”Ӯ
    // в”Ӯ                                 в”Ӯ log4jв”Җapi,       в”Ӯ                  в”Ӯ
    // в”Ӯ                                 в”Ӯ slf4jв”Җapi,       в”Ӯ                  в”Ӯ
    // в”Ӯ                                 в”Ӯ log4jв”Җslf4jв”Җimpl в”Ӯ                  в”Ӯ
    // в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
    -#}
    implementation(platform("org.apache.logging.log4j:log4j-bom:latest.release"))
    implementation("org.apache.logging.log4j", "log4j-api")
    runtimeOnly("org.apache.logging.log4j", "log4j-core")

    ////////////////////////////////////////////////////////////////////////////
    //                              Unit Testing                              //
    ////////////////////////////////////////////////////////////////////////////
    // Unit Test Framework
    //
    // Useful info:
    // - https://junit.org/junit5/docs/current/user-guide/#writing-tests-parameterized-tests-display-names
    testImplementation(platform("org.junit:junit-bom:latest.release"))
    testImplementation("org.junit.jupiter", "junit-jupiter")

    // Unit Test Assertion library
    testImplementation("org.assertj", "assertj-core", "latest.release")
    {#- https://github.com/lukas-krecan/JsonUnit #}

    // Unit Test Mocking Framework
    testImplementation(platform("org.mockito:mockito-bom:latest.release"))
    testImplementation("org.mockito", "mockito-core")
    testImplementation("org.mockito", "mockito-junit-jupiter")
}

tasks {
    test {
        // After running test, always generate report
        finalizedBy(jacocoTestReport)

        useJUnitPlatform()
        testLogging { events(
            TestLogEvent.PASSED,
            TestLogEvent.SKIPPED,
            TestLogEvent.FAILED
        )}
    }

    jacocoTestReport {
        // Before generating report, always run tests
        dependsOn(test)

        reports {
            xml.required = false
            csv.required = false
            html.required = true
        }

        doLast {
            println(
                "See jacoco report at: file://"
                + this@jacocoTestReport
                .reports
                .html
                .outputLocation
                .asFileTree
                .matching { include {
                    // Only consider root directory
                    !it.isDirectory && it.path.contains("index.html")
                }}.singleFile
            )
        }
    }
}
